{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Robot Configuration Schema",
    "type": "object",
    "properties": {
        "states": {
            "type": "object",
            "patternProperties": {
                "^[A-Za-z_][A-Za-z0-9_]*$": {
                    "type": "object",
                    "properties": {
                        "identifier": {
                            "type": "string",
                            "description": "Unique identifier for the state"
                        },
                        "type": {
                            "type": "string",
                            "enum": [
                                "Transform",
                                "Quaternion",
                                "Scalar"
                            ],
                            "description": "Type of the state"
                        },
                        "space": {
                            "type": "string",
                            "enum": [
                                "SMALL",
                                "ALL",
                                "UNUSED"
                            ],
                            "description": "Space classification of the state"
                        },
                        "success": {
                            "type": "string",
                            "enum": [
                                "AREA",
                                "PRECISE",
                                "IGNORE"
                            ],
                            "description": "Success criteria for the state"
                        },
                        "min": {
                            "oneOf": [
                                {
                                    "type": "number"
                                },
                                {
                                    "type": "array",
                                    "items": {
                                        "type": "number"
                                    },
                                    "minItems": 3,
                                    "maxItems": 3
                                }
                            ],
                            "description": "Minimum value(s) for the state"
                        },
                        "max": {
                            "oneOf": [
                                {
                                    "type": "number"
                                },
                                {
                                    "type": "array",
                                    "items": {
                                        "type": "number"
                                    },
                                    "minItems": 3,
                                    "maxItems": 3
                                }
                            ],
                            "description": "Maximum value(s) for the state"
                        }
                    },
                    "required": [
                        "identifier",
                        "type",
                        "space",
                        "success"
                    ],
                    "additionalProperties": false
                }
            },
            "additionalProperties": false
        },
        "tasks": {
            "type": "object",
            "patternProperties": {
                "^[A-Za-z_][A-Za-z0-9_]*$": {
                    "type": "object",
                    "properties": {
                        "precondition": {
                            "type": "object",
                            "patternProperties": {
                                "^[A-Za-z_][A-Za-z0-9_]*$": {
                                    "oneOf": [
                                        {
                                            "type": "string",
                                            "enum": [
                                                "min",
                                                "max"
                                            ]
                                        },
                                        {
                                            "type": "number"
                                        },
                                        {
                                            "type": "array",
                                            "items": {
                                                "type": "number"
                                            }
                                        }
                                    ]
                                }
                            },
                            "description": "Preconditions for the task"
                        },
                        "space": {
                            "type": "string",
                            "enum": [
                                "SMALL",
                                "ALL"
                            ],
                            "description": "Space classification of the task"
                        },
                        "reversed": {
                            "type": "boolean",
                            "description": "Whether the task is reversed"
                        },
                        "ee_tp_start": {
                            "type": "array",
                            "items": {
                                "type": "number"
                            },
                            "minItems": 7,
                            "maxItems": 7,
                            "description": "End effector transform start position (7D pose)"
                        },
                        "obj_start": {
                            "type": "array",
                            "items": {
                                "type": "number"
                            },
                            "minItems": 7,
                            "maxItems": 7,
                            "description": "Object start position (7D pose)"
                        },
                        "ee_hrl_start": {
                            "type": "array",
                            "items": {
                                "type": "number"
                            },
                            "minItems": 7,
                            "maxItems": 7,
                            "description": "End effector HRL start position (7D pose)"
                        }
                    },
                    "required": [
                        "precondition",
                        "space",
                        "reversed",
                        "ee_tp_start",
                        "obj_start",
                        "ee_hrl_start"
                    ],
                    "additionalProperties": false
                }
            },
            "additionalProperties": false
        }
    },
    "required": [
        "states",
        "tasks"
    ],
    "additionalProperties": false
}