{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "States Configuration Schema",
    "description": "Schema for validating robot state definitions",
    "type": "object",
    "patternProperties": {
        "^[a-zA-Z_][a-zA-Z0-9_]*$": {
            "type": "object",
            "description": "A state definition",
            "properties": {
                "type": {
                    "type": "string",
                    "enum": [
                        "Euler",
                        "Quat",
                        "Scalar"
                    ],
                    "description": "The type of the state (Euler angles, Quaternion, or Scalar value)"
                },
                "space": {
                    "type": "string",
                    "enum": [
                        "Minimal",
                        "All",
                        "Unused"
                    ],
                    "description": "The space classification of the state"
                },
                "success": {
                    "type": "string",
                    "enum": [
                        "Precise",
                        "AREA",
                        "Ignore"
                    ],
                    "description": "Success criteria for the state"
                },
                "lower_bound": {
                    "type": "array",
                    "items": {
                        "type": "number"
                    },
                    "description": "Lower bounds for the state values"
                },
                "upper_bound": {
                    "type": "array",
                    "items": {
                        "type": "number"
                    },
                    "description": "Upper bounds for the state values"
                }
            },
            "required": [
                "type",
                "space",
                "success",
                "lower_bound",
                "upper_bound"
            ],
            "additionalProperties": false,
            "allOf": [
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "Euler"
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "lower_bound": {
                                "type": "array",
                                "items": {
                                    "type": "number"
                                },
                                "minItems": 3,
                                "maxItems": 3,
                                "description": "Euler angles require exactly 3 bounds (x, y, z rotations)"
                            },
                            "upper_bound": {
                                "type": "array",
                                "items": {
                                    "type": "number"
                                },
                                "minItems": 3,
                                "maxItems": 3,
                                "description": "Euler angles require exactly 3 bounds (x, y, z rotations)"
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "Quat"
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "lower_bound": {
                                "type": "array",
                                "maxItems": 0,
                                "description": "Quaternions typically don't have explicit bounds (unit sphere constraint)"
                            },
                            "upper_bound": {
                                "type": "array",
                                "maxItems": 0,
                                "description": "Quaternions typically don't have explicit bounds (unit sphere constraint)"
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "Scalar"
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "lower_bound": {
                                "type": "array",
                                "items": {
                                    "type": "number"
                                },
                                "minItems": 1,
                                "maxItems": 1,
                                "description": "Scalar values require exactly 1 bound"
                            },
                            "upper_bound": {
                                "type": "array",
                                "items": {
                                    "type": "number"
                                },
                                "minItems": 1,
                                "maxItems": 1,
                                "description": "Scalar values require exactly 1 bound"
                            }
                        }
                    }
                }
            ]
        }
    },
    "additionalProperties": false,
    "examples": [
        {
            "ee_euler": {
                "type": "Euler",
                "space": "Minimal",
                "success": "Precise",
                "lower_bound": [
                    -1.0,
                    -1.0,
                    -1.0
                ],
                "upper_bound": [
                    1.0,
                    1.0,
                    1.0
                ]
            },
            "ee_quat": {
                "type": "Quat",
                "space": "Minimal",
                "success": "Ignore",
                "lower_bound": [],
                "upper_bound": []
            },
            "ee_state": {
                "type": "Scalar",
                "space": "Minimal",
                "success": "Precise",
                "lower_bound": [
                    0.0
                ],
                "upper_bound": [
                    1.0
                ]
            }
        }
    ]
}